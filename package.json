{
  "name": "balkonbilanz",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:ci",
    "test:unit": "node --test tests/unit/*.test.ts",
    "test:component": "node --test tests/component/*.test.ts",
    "test:smoke": "node --test tests/e2e/mobile-capture.spec.ts tests/node/mobile-pwa-offline.spec.ts tests/bdd/pwa-offline.spec.ts tests/bdd/steps/capture.steps.ts",
    "test:node": "node --test tests/node/githubAutomationConfig.spec.ts",
    "test:ci": "npm run test:unit && npm run test:component && npm run test:smoke && npm run test:node",
    "test:bdd:pwa": "node --test tests/bdd/pwa-offline.spec.ts",
    "test:playwright": "playwright test tests/e2e/mobile-capture.playwright.spec.ts tests/e2e/mobile-pwa-offline.playwright.spec.ts",
    "dev": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "dexie": "4.2.1",
    "fake-indexeddb": "6.0.0",
    "vue": "3.5.34",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@vitejs/plugin-vue": "6.0.1",
    "@vue/compiler-sfc": "3.5.34",
    "happy-dom": "20.9.0",
    "vite": "7.3.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
